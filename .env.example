# ─── LLM ───────────────────────────────────────────────
# Get free at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ─── WEB SEARCH ────────────────────────────────────────
# Get free at: https://tavily.com (1000 free calls/month)
TAVILY_API_KEY=your_tavily_api_key_here

# ─── WEATHER ───────────────────────────────────────────
# Get free at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ─── SPORTS ────────────────────────────────────────────
# Get free at: https://www.api-football.com (also covers cricket, etc.)
API_SPORTS_KEY=your_api_sports_key_here

# ─── GOOGLE (Gmail + Drive) ────────────────────────────
# Create at: https://console.cloud.google.com
# Enable: Gmail API, Google Drive API, Google+ API
# Create OAuth 2.0 credentials (Web Application)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ─── PULSE (Communications — Telegram / Slack / Discord) ──
# Telegram: Message @BotFather, create bot, get token. Get chat ID from @userinfobot or /getids
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
# Slack: Create Incoming Webhook at api.slack.com/apps
SLACK_WEBHOOK_URL=your_slack_webhook_url_here
# Discord: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# ─── APP ───────────────────────────────────────────────
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000
