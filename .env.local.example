# ─────────────────────────────────────────────
# AGENT HQ — Environment Variables
# Copy this file to .env.local and fill in keys
# NEVER commit .env.local to GitHub
# ─────────────────────────────────────────────

# ── LLM: Groq (free at console.groq.com) ──
GROQ_API_KEY=your_groq_api_key_here

# ── Web Search: Tavily (free at app.tavily.com) ──
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Weather: OpenWeatherMap (free at openweathermap.org/api) ──
OPENWEATHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Sports: API-Sports (free tier at api-sports.io) ──
APISPORTS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google OAuth (for Gmail + Drive) ──
# Create at console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback
# After OAuth flow, store tokens here (or use a DB in production)
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=

# ── Pulse (Telegram / Slack / Discord) ──
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
SLACK_WEBHOOK_URL=your_slack_webhook_url_here
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# ── App ──
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXT_PUBLIC_APP_URL=http://localhost:3000
